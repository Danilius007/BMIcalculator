  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #eef2f7, stop:1 #d9e2ec);
}
QLabel#name {
    font-size: 28px;
    font-weight: bold;
    color: #1e293b;
    font-family: 'Segoe UI', Arial, sans-serif;
    padding: 10px;
}
QWidget#right_widget {
    background-color: #ffffff;
    border-radius: 20px;
    padding: 20px;
}
QLabel#image {
    background-color: #f8fafc;
    border: 2px solid #e2e8f0;
    border-radius: 20px;
    padding: 5px;
}
QDoubleSpinBox, QComboBox {
    background-color: #f8fafc;
    border: 2px solid #e2e8f0;
    border-radius: 10px;
    padding: 8px;
    font-size: 14px;
    font-weight: 500;
    color: #1e293b;
}

QDoubleSpinBox:focus, QComboBox:focus {
    border-color: #3b82f6;
    background-color: #ffffff;
}
QComboBox::drop-down {
    border: none;
    width: 20px;
}
QLabel {
    color: #475569;
    font-weight: 600;
    font-size: 13px;
    font-family: 'Segoe UI', Arial, sans-serif;
}
QWidget#result_widget {
    background-color: #f1f5f9;
    border-radius: 15px;
    padding: 15px;
}

QLabel#result {
    font-size: 44px;
    font-weight: bold;
    color: #0f172a;
}

QLabel#state {
    font-size: 20px;
    font-weight: bold;
    color: #1e293b;
}
QPushButton#btn {
    background-color: #3b82f6;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 14px;
    font-size: 16px;
    font-weight: bold;
    font-family: 'Segoe UI', Arial, sans-serif;
}

QPushButton#btn:hover {
    background-color: #2563eb;
}

QPushButton#btn:pressed {
    background-color: #1d4ed8;
}
</string>
